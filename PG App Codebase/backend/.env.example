MONGO_URI=mongodb://127.0.0.1:27017/pg-app

PORT=3000

# Generate a strong random secret for production (e.g. openssl rand -hex 32)
JWT_SECRET=replace_with_a_strong_random_secret

# CORS — comma-separated list of allowed origins
# Development (localhost values are fine for local dev):
# ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
# Production (replace with your actual deployed domains):
# ALLOWED_ORIGINS=https://app.yourdomain.com,https://student.yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

NODE_ENV=production

# Hours before a pending admission is escalated to admin (default: 120 = 5 days)
ESCALATION_THRESHOLD_HOURS=120

# SendGrid — email notifications
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
ADMIN_NOTIFICATION_EMAIL=admin@yourdomain.com

# Twilio — SMS notifications
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1234567890
OWNER_NOTIFICATION_PHONE=+1234567890
