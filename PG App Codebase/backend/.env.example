MONGO_URI=mongodb://127.0.0.1:27017/pg-app

PORT=3000

# Generate strong random secrets: openssl rand -hex 64
JWT_ACCESS_SECRET=replace_with_strong_random_secret
JWT_REFRESH_SECRET=replace_with_different_strong_random_secret

# CORS — comma-separated allowed origins
# Development: http://localhost:5173,http://localhost:5174
# Production: https://app.yourdomain.com,https://student.yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

NODE_ENV=production

# ImageKit — image uploads
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id/

# SMTP — email delivery (OTP, notifications)
# Dev: leave blank to log OTPs/notifications to console instead
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM_EMAIL=noreply@yourdomain.com
ADMIN_NOTIFICATION_EMAIL=admin@yourdomain.com
